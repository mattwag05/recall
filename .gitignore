# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.swp
*.swo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# SQLite database
/prisma/*.db
/prisma/*.db-shm
/prisma/*.db-wal
prisma/dev.db
prisma/dev.db-shm
prisma/dev.db-wal

# Media cache
/public/media/
public/media/
/data/media/
data/media/

# Environment
.env.local

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Project-local MCP config (per-machine, may contain host URLs)
.mcp.json

# MCP server deps
/mcp-server/node_modules/

# Pake desktop build output
/dist-app/

# Preview MCP launch config (session-local)
.claude/

# Personal/agent files (untracked for public release)
CLAUDE.md
AGENTS.md
.beads/
.remember/
